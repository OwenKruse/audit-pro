# UI (server-side)
AGENT_HTTP_URL="http://127.0.0.1:17400"
# Sourcify server for ABI lookup (optional; default: https://sourcify.dev/server)
# SOURCIFY_SERVER_URL="https://sourcify.dev/server"
# Optional alias used by contract-metadata route/tool
# SOURCIFY_BASE_URL="https://sourcify.dev/server"
# Optional override for DEX explorer data source (default: https://api.llama.fi)
# LLAMA_BASE_URL="https://api.llama.fi"
# Optional DeFiLlama Pro endpoint (kept as a fallback; some protocol endpoints are only on api.llama.fi)
# LLAMA_PRO_BASE_URL="https://pro-api.llama.fi"

# UI (browser-side)
NEXT_PUBLIC_AGENT_WS_URL="ws://127.0.0.1:17400"

# Agent
AGENT_HOST="127.0.0.1"
AGENT_PORT="17400"
AGENT_PROXY_HOST="127.0.0.1"
AGENT_PROXY_PORT="18080"
# Auto-rewrite outbound EVM JSON-RPC requests (non-loopback) to the local RPC.
AGENT_PROXY_RPC_REWRITE_ENABLED="1"
# Optional explicit rewrite target. Defaults to the current Foundry RPC URL.
# AGENT_PROXY_RPC_REWRITE_URL="http://127.0.0.1:8545"
AGENT_DB_PATH="./apps/agent/.data/cipherscope.db"
LOG_LEVEL="info"

# Foundry / Anvil (backend-managed local EVM RPC)
# If enabled, the agent will check AGENT_FOUNDRY_RPC_HOST:AGENT_FOUNDRY_RPC_PORT on startup.
# If nothing is listening and autostart is enabled, it will launch `anvil`.
AGENT_FOUNDRY_ENABLED="1"
AGENT_FOUNDRY_AUTOSTART="1"
AGENT_FOUNDRY_BINARY="anvil"
AGENT_FOUNDRY_RPC_HOST="127.0.0.1"
AGENT_FOUNDRY_RPC_PORT="8545"
AGENT_FOUNDRY_CHAIN_ID="1"
AGENT_FOUNDRY_STARTUP_TIMEOUT_MS="15000"
# Optional:
# AGENT_FOUNDRY_FORK_URL=""  # default is https://ethereum-rpc.publicnode.com
# AGENT_FOUNDRY_FORK_FALLBACK_URLS="https://eth.llamarpc.com https://eth.merkle.io https://rpc.flashbots.net"
# AGENT_FOUNDRY_FORK_BLOCK_NUMBER=""
# AGENT_FOUNDRY_BLOCK_TIME=""
# AGENT_FOUNDRY_ARGS="--steps-tracing"

# TLS MITM (recommended for real dapp capture)
AGENT_MITM_ENABLED="1"

# If set to "1", the agent will allow upstream HTTPS with invalid/self-signed certs.
# (Useful for local dev/staging targets.)
AGENT_UPSTREAM_INSECURE="0"

# OWASP ZAP API (used by the left-nav scanner and AI start_scan/get_scan tools)
# ZAP_API_URL="http://127.0.0.1:8080"
# ZAP_API_KEY=""

# Subfinder (used by the left-nav scanner tab and AI run_subfinder tool)
# SUBFINDER_BINARY="subfinder"
# SUBFINDER_TIMEOUT_MS="240000"
# SUBFINDER_DEFAULT_SOURCES="anubis,crtsh,hackertarget,rapiddns,threatcrowd,waybackarchive"

# AI (optional; do not commit secrets)
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-5.1-mini"
# OPENAI_BASE_URL="https://api.openai.com/v1"

# OpenRouter (optional; used when provider=openrouter)
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="openai/gpt-5.1-mini"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_HTTP_REFERER="http://localhost:3000"
# OPENROUTER_X_TITLE="CipherScope"

# Gemini (optional; used when provider=gemini via OpenAI-compatible endpoint)
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-3.0-flash"
# GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"

# Grok / xAI (optional; used when provider=grok)
# GROK_API_KEY=""
# GROK_MODEL="grok-2-latest"
# GROK_BASE_URL="https://api.x.ai/v1"
# Optional xAI aliases:
# XAI_API_KEY=""
# XAI_MODEL="grok-2-latest"
# XAI_BASE_URL="https://api.x.ai/v1"

# Claude / Anthropic (optional; used when provider=claude)
# CLAUDE_API_KEY=""
# CLAUDE_MODEL="claude-3-5-sonnet-latest"
# CLAUDE_BASE_URL="https://api.anthropic.com"
# CLAUDE_API_VERSION="2023-06-01"
# Optional Anthropic aliases:
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
# ANTHROPIC_BASE_URL="https://api.anthropic.com"
# ANTHROPIC_VERSION="2023-06-01"

# DeepSeek (optional; used when provider=deepseek)
# DEEPSEEK_API_KEY=""
# DEEPSEEK_MODEL="deepseek-chat"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Optional Etherscan API key (used by contract metadata fallback)
# ETHERSCAN_API_KEY=""
# Optional ZoomEye API key (used by ZoomEye host search page + AI tool)
# ZOOMEYE_API_KEY=""
# Optional Shodan API key (used by host search page + AI tool)
# SHODAN_API_KEY=""
# Optional: many models support custom temperatures; some (e.g. gpt-5*) may only support the default.
# AI_TEMPERATURE="0.2"
# OPENAI_TEMPERATURE="0.2"

# AI tools (optional safety gates)
# If set to "1", allow the AI curl-like tool (http_request) to call any host.
# Default: restricted to hosts present in the captured sitemap.
AGENT_AI_HTTP_ALLOW_ANY_HOST="0"

# If set to "1", allow rpc_request to call state-changing JSON-RPC methods
# (eth_send*, anvil_*, hardhat_*, evm_*, personal_*, wallet_*).
AGENT_AI_ALLOW_RPC_SIDE_EFFECTS="0"
